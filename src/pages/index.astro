---
// Root: simple language picker.
// Optionally redirect based on browser language with a small client script.
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Choose your language &middot; ભાષા પસંદ કરો</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=Noto+Sans+Gujarati:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <style>
      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        background: #0f172a;
        color: #f8fafc;
        font-family: 'Inter', system-ui, sans-serif;
        text-align: center;
        padding: 2rem;
      }
      h1 { font-size: 2rem; margin: 0 0 2rem; font-weight: 600; }
      .gu { font-family: 'Noto Sans Gujarati', sans-serif; }
      .choices { display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center; }
      a {
        color: #f8fafc;
        text-decoration: none;
        padding: 0.85rem 1.75rem;
        border: 1px solid #334155;
        border-radius: 8px;
        transition: background 0.15s;
      }
      a:hover { background: #1e293b; }
    </style>
  </head>
  <body>
    <div>
      <h1>Welcome &middot; <span class="gu">સ્વાગત છે</span></h1>
      <div class="choices">
        <a href="/en/">English</a>
        <a class="gu" href="/gu/">ગુજરાતી</a>
      </div>
    </div>
  </body>
</html>
