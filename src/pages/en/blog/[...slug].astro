---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Giscus from '../../../components/Giscus.astro';
import Lyket from '../../../components/Lyket.astro';
import Share from '../../../components/Share.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.lang === 'en' && !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug.replace(/^en\//, '') },
    props: { post },
  }));
}

type Props = { post: CollectionEntry<'blog'> };
const { post } = Astro.props;
const { Content } = await post.render();

const formatted = post.data.pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const site = Astro.site?.toString().replace(/\/$/, '') ?? '';
const postUrl = `${site}/en/blog/${post.slug.replace(/^en\//, '')}/`;
---
<BaseLayout
  lang="en"
  pageType="blog-post"
  postSlug={post.slug.replace(/^en\//, '')}
  postTags={post.data.tags}
  title={`${post.data.title} — Kunal`}
  description={post.data.description}
>
  <article>
    <h1>{post.data.title}</h1>
    <time datetime={post.data.pubDate.toISOString()}>{formatted}</time>
    {post.data.tags.length > 0 && (
      <ul class="tags post-meta" aria-label="Tags">
        {post.data.tags.map((t) => <li class="tag">{t}</li>)}
      </ul>
    )}
    <Content />
  </article>

  <Share title={post.data.title} url={postUrl} lang="en" />

  <Lyket id={post.slug.replace(/^en\//, '')} namespace="en" />

  <Giscus lang="en" />

  <hr />
  <p><a href="/en/blog/">&larr; All posts</a></p>
</BaseLayout>
