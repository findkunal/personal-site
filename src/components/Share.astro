---
interface Props {
  title: string;
  url: string;
  lang: 'en' | 'gu';
}

const { title: t, url: u, lang: l } = Astro.props;

const strings = {
  en: {
    label: 'Share',
    copy: 'Copy link',
    copied: 'Copied!',
    twitter: 'Share on X',
    linkedin: 'Share on LinkedIn',
    facebook: 'Share on Facebook',
    whatsapp: 'Share on WhatsApp',
    native: 'Share',
  },
  gu: {
    label: 'શેર કરો',
    copy: 'લિંક કૉપિ કરો',
    copied: 'કૉપિ થઈ ગયું!',
    twitter: 'X પર શેર કરો',
    linkedin: 'LinkedIn પર શેર કરો',
    facebook: 'Facebook પર શેર કરો',
    whatsapp: 'WhatsApp પર શેર કરો',
    native: 'શેર કરો',
  },
}[l];

const encodedUrl = encodeURIComponent(u);
const encodedTitle = encodeURIComponent(t);

const twitter = `https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`;
const linkedin = `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`;
const facebook = `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`;
const whatsapp = `https://api.whatsapp.com/send?text=${encodedTitle}%20${encodedUrl}`;
---

<div class="share" data-share-url={u} data-share-title={t} data-copied-text={strings.copied}>
  <span class="share__label">{strings.label}:</span>

  <button type="button" class="share__btn share__native" data-action="native" hidden aria-label={strings.native} title={strings.native}>
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="18" cy="5" r="3" />
      <circle cx="6" cy="12" r="3" />
      <circle cx="18" cy="19" r="3" />
      <line x1="8.59" y1="13.51" x2="15.42" y2="17.49" />
      <line x1="15.41" y1="6.51" x2="8.59" y2="10.49" />
    </svg>
  </button>

  <a class="share__btn" href={twitter} target="_blank" rel="noopener noreferrer" aria-label={strings.twitter} title={strings.twitter}>
    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
    </svg>
  </a>

  <a class="share__btn" href={linkedin} target="_blank" rel="noopener noreferrer" aria-label={strings.linkedin} title={strings.linkedin}>
    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
    </svg>
  </a>

  <a class="share__btn" href={facebook} target="_blank" rel="noopener noreferrer" aria-label={strings.facebook} title={strings.facebook}>
    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/>
    </svg>
  </a>

  <a class="share__btn" href={whatsapp} target="_blank" rel="noopener noreferrer" aria-label={strings.whatsapp} title={strings.whatsapp}>
    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.149-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/>
    </svg>
  </a>

  <button type="button" class="share__btn" data-action="copy" aria-label={strings.copy} title={strings.copy}>
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
      <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
    </svg>
  </button>

  <span class="share__toast" role="status" aria-live="polite"></span>
</div>

<script is:inline>
  (function () {
    document.querySelectorAll('.share').forEach(function (root) {
      var url = root.getAttribute('data-share-url') || window.location.href;
      var title = root.getAttribute('data-share-title') || document.title;
      var copiedText = root.getAttribute('data-copied-text') || 'Copied!';
      var nativeBtn = root.querySelector('[data-action="native"]');
      var copyBtn = root.querySelector('[data-action="copy"]');
      var toast = root.querySelector('.share__toast');

      if (nativeBtn && typeof navigator.share === 'function') {
        nativeBtn.hidden = false;
        nativeBtn.addEventListener('click', function () {
          navigator.share({ title: title, url: url }).catch(function () {});
          if (typeof window.gtag === 'function') {
            window.gtag('event', 'share', { method: 'native', content_type: 'post', item_id: url });
          }
        });
      }

      if (copyBtn) {
        copyBtn.addEventListener('click', function () {
          var done = function () {
            if (toast) {
              toast.textContent = copiedText;
              setTimeout(function () { toast.textContent = ''; }, 1800);
            }
            if (typeof window.gtag === 'function') {
              window.gtag('event', 'share', { method: 'copy_link', content_type: 'post', item_id: url });
            }
          };
          if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(url).then(done).catch(function () {
              fallbackCopy(url); done();
            });
          } else {
            fallbackCopy(url); done();
          }
        });
      }

      // Track outbound social share clicks too.
      root.querySelectorAll('a.share__btn').forEach(function (a) {
        a.addEventListener('click', function () {
          if (typeof window.gtag !== 'function') return;
          var label = a.getAttribute('aria-label') || '';
          var method = label.toLowerCase().indexOf('linkedin') >= 0 ? 'linkedin'
            : label.toLowerCase().indexOf('facebook') >= 0 ? 'facebook'
            : label.toLowerCase().indexOf('whatsapp') >= 0 ? 'whatsapp'
            : 'twitter';
          window.gtag('event', 'share', { method: method, content_type: 'post', item_id: url });
        });
      });

      function fallbackCopy(text) {
        var ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        try { document.execCommand('copy'); } catch (_) {}
        document.body.removeChild(ta);
      }
    });
  })();
</script>

<style>
  .share {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 2rem 0 1rem;
    padding: 0.75rem 1rem;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    font-size: 0.95rem;
  }
  :root[data-theme="dark"] .share { border-color: #334155; }
  @media (prefers-color-scheme: dark) {
    .share { border-color: #334155; }
  }
  .share__label {
    font-weight: 600;
    margin-right: 0.25rem;
  }
  .share__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 6px;
    border: 1px solid transparent;
    background: transparent;
    color: inherit;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }
  .share__btn:hover {
    background: #f1f5f9;
  }
  @media (prefers-color-scheme: dark) {
    .share__btn:hover { background: #1e293b; }
  }
  .share__toast {
    margin-left: 0.25rem;
    font-size: 0.85rem;
    color: #16a34a;
    min-height: 1em;
  }
</style>
