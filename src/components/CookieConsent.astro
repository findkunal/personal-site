---
interface Props {
  lang: 'en' | 'gu';
}

const { lang } = Astro.props;

const strings = {
  en: {
    message:
      'This site uses cookies and Google Analytics to understand how readers find and use the blog. No personal data is sold or shared.',
    accept: 'Accept',
    decline: 'Decline',
    learnMore: 'Learn more',
    learnMoreHref: '/en/privacy/',
  },
  gu: {
    message:
      'આ સાઇટ વાચકો બ્લોગને કેવી રીતે શોધે અને વાપરે છે એ સમજવા માટે કૂકીઝ અને Google Analytics નો ઉપયોગ કરે છે. કોઈ વ્યક્તિગત માહિતી વેચવામાં કે શેર કરવામાં આવતી નથી.',
    accept: 'સ્વીકારો',
    decline: 'નકારો',
    learnMore: 'વધુ જાણો',
    learnMoreHref: '/gu/privacy/',
  },
}[lang];
---

<div id="cookie-consent" class="cookie-consent" hidden role="dialog" aria-live="polite" aria-label="Cookie consent">
  <p class="cookie-consent__message">
    {strings.message}
    {' '}
    <a href={strings.learnMoreHref}>{strings.learnMore}</a>
  </p>
  <div class="cookie-consent__actions">
    <button type="button" data-consent-action="decline" class="cookie-consent__btn cookie-consent__btn--secondary">
      {strings.decline}
    </button>
    <button type="button" data-consent-action="accept" class="cookie-consent__btn cookie-consent__btn--primary">
      {strings.accept}
    </button>
  </div>
</div>

<script is:inline>
  (function () {
    var STORAGE_KEY = 'cookie-consent-v1';
    var banner = document.getElementById('cookie-consent');
    if (!banner) return;

    var stored = null;
    try { stored = localStorage.getItem(STORAGE_KEY); } catch (_) {}

    function applyConsent(state) {
      if (typeof window.gtag !== 'function') return;
      var granted = state === 'accept' ? 'granted' : 'denied';
      window.gtag('consent', 'update', {
        analytics_storage: granted,
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
      });
    }

    function setConsent(state) {
      try { localStorage.setItem(STORAGE_KEY, state); } catch (_) {}
      applyConsent(state);
      banner.hidden = true;
    }

    if (stored === 'accept' || stored === 'decline') {
      // Apply previously chosen consent for this session, then stay hidden.
      applyConsent(stored);
      banner.hidden = true;
    } else {
      banner.hidden = false;
    }

    banner.addEventListener('click', function (ev) {
      var btn = ev.target && ev.target.closest && ev.target.closest('[data-consent-action]');
      if (!btn) return;
      setConsent(btn.getAttribute('data-consent-action'));
    });
  })();
</script>

<style>
  .cookie-consent {
    position: fixed;
    left: 1rem;
    right: 1rem;
    bottom: 1rem;
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
    background: #0f172a;
    color: #f8fafc;
    border: 1px solid #334155;
    border-radius: 10px;
    padding: 1rem 1.25rem;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
    z-index: 1000;
    font-size: 0.95rem;
    line-height: 1.5;
  }
  .cookie-consent[hidden] { display: none; }
  .cookie-consent__message { margin: 0 0 0.75rem; }
  .cookie-consent__message a { color: #93c5fd; }
  .cookie-consent__actions {
    display: flex;
    gap: 0.5rem;
    justify-content: flex-end;
    flex-wrap: wrap;
  }
  .cookie-consent__btn {
    appearance: none;
    border: 1px solid #334155;
    background: transparent;
    color: inherit;
    padding: 0.5rem 1rem;
    border-radius: 6px;
    cursor: pointer;
    font: inherit;
  }
  .cookie-consent__btn:hover { background: #1e293b; }
  .cookie-consent__btn--primary {
    background: #f8fafc;
    color: #0f172a;
    border-color: #f8fafc;
  }
  .cookie-consent__btn--primary:hover { background: #e2e8f0; }
</style>
