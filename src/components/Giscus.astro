---
interface Props {
  lang: 'en' | 'gu';
}

const { lang } = Astro.props;

const REPO_ID = 'R_kgDOSQW60w';
// Get CATEGORY_ID from: giscus.app → type "findkunal/personal-site" → copy data-category-id
const CATEGORY_ID = 'DIC_kwDOSQW6084C8DoT';

// Giscus doesn't support Gujarati ('gu') as a UI language, so fall back to English.
const giscusLang = lang === 'gu' ? 'en' : lang;
---

<section class="giscus-wrapper">
  <script
    src="https://giscus.app/client.js"
    data-repo="findkunal/personal-site"
    data-repo-id={REPO_ID}
    data-category="Announcements"
    data-category-id={CATEGORY_ID}
    data-mapping="pathname"
    data-strict="0"
    data-reactions-enabled="1"
    data-emit-metadata="0"
    data-input-position="top"
    data-theme="preferred_color_scheme"
    data-lang={giscusLang}
    crossorigin="anonymous"
    async
  ></script>
</section>
