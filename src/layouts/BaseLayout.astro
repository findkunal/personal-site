---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  lang: 'en' | 'gu';
}

const { title, description = '', lang } = Astro.props;
const otherLang = lang === 'en' ? 'gu' : 'en';
const otherLabel = lang === 'en' ? 'ગુજરાતી' : 'English';
const homeLabel = lang === 'en' ? 'Home' : 'ઘર';
const blogLabel = lang === 'en' ? 'Blog' : 'બ્લોગ';

const site = Astro.site?.toString().replace(/\/$/, '') ?? '';
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={lang === 'en' ? 'en_US' : 'gu_IN'} />

    <!-- hreflang for multilingual SEO -->
    <link rel="alternate" hreflang="en" href={`${site}/en/`} />
    <link rel="alternate" hreflang="gu" href={`${site}/gu/`} />
    <link rel="alternate" hreflang="x-default" href={`${site}/en/`} />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title={`Blog (${lang})`} href={`/${lang}/rss.xml`} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Noto+Sans+Gujarati:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-WFL8DMMYGQ"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-WFL8DMMYGQ');
    </script>
  </head>
  <body>
    <nav class="site-nav">
      <div class="links">
        <a href={`/${lang}/`}>{homeLabel}</a>
        <a href={`/${lang}/blog/`}>{blogLabel}</a>
        <a href={`/${otherLang}/`}>{otherLabel}</a>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer>
      <p>&copy; {new Date().getFullYear()} Kunal &middot; <a href={`/${lang}/rss.xml`}>RSS</a></p>
    </footer>
  </body>
</html>
