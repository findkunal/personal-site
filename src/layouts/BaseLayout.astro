---
import '../styles/global.css';
import CookieConsent from '../components/CookieConsent.astro';

interface Props {
  title: string;
  description?: string;
  lang: 'en' | 'gu';
  pageType?: 'home' | 'blog-index' | 'blog-post' | 'other';
  postSlug?: string;
  postTags?: string[];
}

const {
  title,
  description = '',
  lang,
  pageType = 'other',
  postSlug,
  postTags = [],
} = Astro.props;
const otherLang = lang === 'en' ? 'gu' : 'en';
const otherLabel = lang === 'en' ? 'ગુજરાતી' : 'English';
const homeLabel = lang === 'en' ? 'Home' : 'ઘર';

const site = Astro.site?.toString().replace(/\/$/, '') ?? '';

// Build GA config object server-side so we don't ship the logic to every client.
const gaConfig: Record<string, unknown> = {
  content_group: pageType,
  content_language: lang,
};
if (pageType === 'blog-post' && postSlug) {
  gaConfig.post_slug = postSlug;
  gaConfig.post_language = lang;
  if (postTags.length > 0) gaConfig.post_tags = postTags.join(',');
}
const gaConfigJson = JSON.stringify(gaConfig);
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={lang === 'en' ? 'en_US' : 'gu_IN'} />

    <!-- hreflang for multilingual SEO -->
    <link rel="alternate" hreflang="en" href={`${site}/en/`} />
    <link rel="alternate" hreflang="gu" href={`${site}/gu/`} />
    <link rel="alternate" hreflang="x-default" href={`${site}/en/`} />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title={`Blog (${lang})`} href={`/${lang}/rss.xml`} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;0,8..60,700;1,8..60,400&family=Noto+Sans+Gujarati:wght@400;600;700&family=Noto+Serif+Gujarati:wght@400;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Google Analytics (GA4). Honours Do Not Track and Consent Mode v2. -->
    <script is:inline define:vars={{ gaConfigJson }}>
      (function () {
        try {
          var dnt =
            navigator.doNotTrack === '1' ||
            window.doNotTrack === '1' ||
            navigator.msDoNotTrack === '1';
          if (dnt) return;

          window.dataLayer = window.dataLayer || [];
          window.gtag = function () { window.dataLayer.push(arguments); };

          // Consent Mode v2: default-deny until the user opts in.
          // The cookie consent banner will call gtag('consent', 'update', ...) on accept.
          var prior = null;
          try { prior = localStorage.getItem('cookie-consent-v1'); } catch (_) {}
          window.gtag('consent', 'default', {
            analytics_storage: prior === 'accept' ? 'granted' : 'denied',
            ad_storage: 'denied',
            ad_user_data: 'denied',
            ad_personalization: 'denied',
            wait_for_update: 500,
          });

          var s = document.createElement('script');
          s.async = true;
          s.src = 'https://www.googletagmanager.com/gtag/js?id=G-WFL8DMMYGQ';
          document.head.appendChild(s);

          window.gtag('js', new Date());
          window.gtag('config', 'G-WFL8DMMYGQ', JSON.parse(gaConfigJson));
        } catch (e) { /* swallow */ }
      })();
    </script>
  </head>
  <body>
    <nav class="site-nav">
      <div class="links">
        <a href={`/${lang}/`}>{homeLabel}</a>
        <a href={`/${otherLang}/`}>{otherLabel}</a>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer>
      <p>
        &copy; {new Date().getFullYear()} Kunal &middot;
        <a href={`/${lang}/rss.xml`}>RSS</a> &middot;
        <a href={`/${lang}/privacy/`}>{lang === 'en' ? 'Privacy' : 'ગોપનીયતા'}</a>
      </p>
    </footer>

    <CookieConsent lang={lang} />

    <!-- GA enrichment: outbound link clicks + scroll depth milestones. -->
    <script is:inline>
      (function () {
        if (!('gtag' in window)) return;
        var gtag = window.gtag;

        // Outbound link tracking.
        document.addEventListener('click', function (ev) {
          var a = ev.target && ev.target.closest && ev.target.closest('a[href]');
          if (!a) return;
          var href = a.getAttribute('href') || '';
          if (!/^https?:\/\//i.test(href)) return;
          try {
            var url = new URL(href);
            if (url.hostname === window.location.hostname) return;
            gtag('event', 'click_outbound', {
              link_url: href,
              link_domain: url.hostname,
              link_text: (a.textContent || '').trim().slice(0, 100),
            });
          } catch (_) { /* ignore */ }
        }, { passive: true });

        // Scroll depth milestones (25/50/75/100), once per page.
        var fired = {};
        function onScroll() {
          var doc = document.documentElement;
          var scrolled = (window.scrollY || doc.scrollTop) + window.innerHeight;
          var height = Math.max(doc.scrollHeight, doc.offsetHeight, document.body.scrollHeight);
          if (height <= 0) return;
          var pct = Math.min(100, Math.round((scrolled / height) * 100));
          [25, 50, 75, 100].forEach(function (m) {
            if (!fired[m] && pct >= m) {
              fired[m] = true;
              gtag('event', 'scroll_depth', { percent: m });
            }
          });
        }
        var ticking = false;
        window.addEventListener('scroll', function () {
          if (ticking) return;
          ticking = true;
          window.requestAnimationFrame(function () { onScroll(); ticking = false; });
        }, { passive: true });
        // Run once on load in case the page is short.
        onScroll();
      })();
    </script>
  </body>
</html>
